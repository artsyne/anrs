{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://artsyne.github.io/anrs/schemas/skill_registry.schema.json",
  "title": "ANRS Skill Registry Schema",
  "description": "Schema for the skill registry file (ai/skills/index.json)",
  "type": "object",
  
  "required": ["version", "last_updated", "skills", "metadata"],
  
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema file"
    },
    
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Registry version following semver"
    },
    
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Last update date (YYYY-MM-DD)"
    },
    
    "skills": {
      "type": "object",
      "description": "Skill categories and their items",
      "additionalProperties": {
        "$ref": "#/definitions/skill_category"
      }
    },
    
    "metadata": {
      "type": "object",
      "required": ["total_skills", "categories"],
      "properties": {
        "total_skills": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of registered skills"
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of category names"
        }
      }
    }
  },
  
  "definitions": {
    "skill_category": {
      "type": "object",
      "required": ["description", "items"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Category description"
        },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/skill_item" }
        }
      }
    },
    
    "skill_item": {
      "type": "object",
      "required": ["name", "path", "triggers", "description"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique skill identifier (kebab-case)"
        },
        "path": {
          "type": "string",
          "description": "Relative path from ai/skills/"
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Keywords that trigger this skill"
        },
        "description": {
          "type": "string",
          "maxLength": 200,
          "description": "Brief description of what the skill does"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Skill version (semver)"
        },
        "stability": {
          "type": "string",
          "enum": ["stable", "experimental", "deprecated"],
          "description": "Skill stability level"
        }
      },
      "additionalProperties": false
    }
  },
  
  "additionalProperties": false
}
