{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ahes.dev/schemas/plan.schema.json",
  "title": "AHES Plan Schema",
  "description": "Schema for plan metadata in plans/active/{task_id}.md. Plans are Markdown files with this structured content.",
  "type": "object",
  
  "required": ["task_id", "objective", "steps", "acceptance_criteria"],
  
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z]+-\\d{3,}$",
      "description": "Unique task identifier (e.g., task-001, todo-001)"
    },
    
    "objective": {
      "type": "string",
      "maxLength": 200,
      "description": "Single-sentence description of the task goal"
    },
    
    "requirements": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of requirements for this task"
    },
    
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "skipped"],
            "default": "pending"
          }
        }
      },
      "description": "Ordered list of steps to complete the task"
    },
    
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string" },
          "verified": { "type": "boolean", "default": false }
        }
      },
      "description": "Measurable criteria for task completion"
    },
    
    "estimated_effort": {
      "type": "string",
      "description": "Estimated time to complete (e.g., '2 hours', '1 day')"
    },
    
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    
    "commit_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$",
      "description": "Git commit hash when plan was completed"
    }
  },
  
  "additionalProperties": true
}
