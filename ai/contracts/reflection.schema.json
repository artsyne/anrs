{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://artsyne.github.io/anrs/schemas/reflection.schema.json",
  "title": "ANRS Reflection Schema",
  "description": "Schema for reflection output during failure recovery",
  "type": "object",
  
  "required": ["error", "analysis", "fix_plan"],
  
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z]+-\\d{3,}$",
      "description": "Related task ID (e.g., task-001, todo-001)"
    },
    
    "attempt_number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Current retry attempt number"
    },
    
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "description": "Error code from harness"
        },
        "message": {
          "type": "string",
          "description": "Full error message"
        },
        "file": {
          "type": "string",
          "description": "File where error occurred"
        },
        "line": {
          "type": "integer",
          "description": "Line number if applicable"
        },
        "stack_trace": {
          "type": "string",
          "description": "Stack trace if available"
        }
      }
    },
    
    "analysis": {
      "type": "object",
      "required": ["root_cause", "category"],
      "properties": {
        "root_cause": {
          "type": "string",
          "description": "Identified root cause of the error"
        },
        "category": {
          "type": "string",
          "enum": ["syntax", "logic", "type", "test", "lint", "security", "performance", "other"],
          "description": "Error category"
        },
        "why_analysis": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "5 Whys analysis steps"
        },
        "contributing_factors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Other factors that contributed"
        }
      }
    },
    
    "fix_plan": {
      "type": "object",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["action"],
            "properties": {
              "action": {
                "type": "string",
                "description": "What action to take"
              },
              "file": {
                "type": "string",
                "description": "File to modify"
              },
              "details": {
                "type": "string",
                "description": "Additional details"
              }
            }
          }
        },
        "verification": {
          "type": "string",
          "description": "How to verify the fix works"
        },
        "estimated_success": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Estimated probability of success"
        }
      }
    },
    
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  
  "additionalProperties": false
}
