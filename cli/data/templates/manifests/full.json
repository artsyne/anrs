{
  "name": "full",
  "description": "Level 2: Full ANRS setup with skills, harness, and failure tracking",
  "level": 2,
  "extends": "standard",
  "files": [
    {
      "source": "skills/index.template.json",
      "target": ".anrs/skills/index.json"
    },
    {
      "source": "harness/config.template.json",
      "target": ".anrs/harness/config.json"
    },
    {
      "source": "failure-cases/README.md",
      "target": ".anrs/failure-cases/README.md"
    }
  ],
  "directories": [
    ".anrs/skills",
    ".anrs/failure-cases",
    ".anrs/harness"
  ],
  "post_init": [
    "echo 'Full ANRS setup complete. Run anrs harness to verify.'"
  ]
}
