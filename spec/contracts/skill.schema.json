{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://artsyne.github.io/anrs/schemas/skill.schema.json",
  "title": "ANRS Skill Schema",
  "description": "Schema for skill definitions in spec/skills/index.json",
  "type": "object",
  
  "required": ["name", "path", "triggers", "description"],
  
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Unique skill identifier (kebab-case)"
    },
    
    "path": {
      "type": "string",
      "description": "Relative path from spec/skills/"
    },
    
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Keywords that trigger this skill"
    },
    
    "description": {
      "type": "string",
      "maxLength": 200,
      "description": "Brief description of what the skill does"
    },
    
    "input_schema": {
      "type": "object",
      "description": "JSON Schema for skill input"
    },
    
    "output_schema": {
      "type": "object",
      "description": "JSON Schema for skill output"
    },
    
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of constraints for this skill"
    },
    
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Other skills this skill depends on"
    },
    
    "agent_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["developer", "sre", "review"]
      },
      "description": "Agent types allowed to use this skill"
    },
    
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Skill version (semver)"
    }
  },
  
  "additionalProperties": false
}
