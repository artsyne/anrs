{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://artsyne.github.io/anrs/schemas/task.schema.json",
  "title": "ANRS Task Schema",
  "description": "Schema for task definition in plans/active/",
  "type": "object",
  
  "required": ["task_id", "objective", "requirements", "steps", "acceptance_criteria"],
  
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z]+-\\d{3,}$",
      "description": "Unique task identifier (e.g., task-001, todo-001, feat-001)"
    },
    
    "objective": {
      "type": "string",
      "maxLength": 200,
      "description": "Single-sentence description of the task goal"
    },
    
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "List of requirements for this task"
    },
    
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "skipped"],
            "default": "pending"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        }
      },
      "description": "Ordered list of steps to complete the task"
    },
    
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": {
            "type": "string"
          },
          "verified": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "description": "Measurable criteria for task completion"
    },
    
    "estimated_effort": {
      "type": "string",
      "description": "Estimated time to complete (e.g., '2 hours', '1 day')"
    },
    
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "default": "medium"
    },
    
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for categorization"
    },
    
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  
  "additionalProperties": false
}
