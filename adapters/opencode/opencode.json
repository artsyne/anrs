{
  "$schema": "https://opencode.ai/config.json",
  "$comment": "AHES Configuration for OpenCode",
  
  "agent": {
    "ahes-build": {
      "description": "AHES-compliant build agent with full tool access",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./agents/ahes-build.md}",
      "temperature": 0.3,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "ahes-plan": {
      "description": "AHES-compliant planning agent (read-only)",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./agents/ahes-plan.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "ahes-review": {
      "description": "AHES-compliant code review subagent",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./agents/ahes-review.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  }
}
