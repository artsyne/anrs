{
  "$schema": "https://opencode.ai/config.json",
  "$comment": "ANRS Configuration for OpenCode",
  
  "agent": {
    "anrs-build": {
      "description": "ANRS-compliant build agent with full tool access",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./agents/anrs-build.md}",
      "temperature": 0.3,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "anrs-plan": {
      "description": "ANRS-compliant planning agent (read-only)",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./agents/anrs-plan.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "anrs-review": {
      "description": "ANRS-compliant code review subagent",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./agents/anrs-review.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  }
}
