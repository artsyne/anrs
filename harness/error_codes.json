{
  "$comment": "ANRS Error Codes - Reference for AI agents during reflection",
  
  "categories": {
    "E1xx": "Static Analysis Errors",
    "E2xx": "Test Errors",
    "E3xx": "Stability Errors",
    "E4xx": "Security Errors",
    "E5xx": "Protocol Errors",
    "E6xx": "Environment Errors"
  },
  
  "errors": {
    "E101": {
      "name": "syntax_error",
      "category": "static",
      "severity": "critical",
      "message": "Syntax error in source file",
      "recovery": "Fix syntax error at specified line"
    },
    "E102": {
      "name": "lint_error",
      "category": "static",
      "severity": "high",
      "message": "Lint rule violation",
      "recovery": "Fix lint issue or disable rule with justification"
    },
    "E103": {
      "name": "complexity_exceeded",
      "category": "static",
      "severity": "medium",
      "message": "Function complexity exceeds threshold",
      "recovery": "Refactor function into smaller units"
    },
    "E104": {
      "name": "type_error",
      "category": "static",
      "severity": "critical",
      "message": "Type checking failed",
      "recovery": "Fix type mismatch"
    },
    
    "E201": {
      "name": "test_failed",
      "category": "test",
      "severity": "critical",
      "message": "Unit test failed",
      "recovery": "Fix code to pass test or update test if incorrect"
    },
    "E202": {
      "name": "coverage_low",
      "category": "test",
      "severity": "high",
      "message": "Test coverage below threshold",
      "recovery": "Add tests for uncovered code paths"
    },
    "E203": {
      "name": "contract_violation",
      "category": "test",
      "severity": "high",
      "message": "API contract violation",
      "recovery": "Align implementation with contract or update contract"
    },
    
    "E301": {
      "name": "risk_analysis_high",
      "category": "stability",
      "severity": "high",
      "message": "High-risk failure mode detected (RPN >= 100)",
      "recovery": "Add mitigation for identified failure mode"
    },
    "E302": {
      "name": "slo_breach",
      "category": "stability",
      "severity": "critical",
      "message": "Service Level Objective not met",
      "recovery": "Optimize to meet SLO target"
    },
    
    "E401": {
      "name": "vulnerability_found",
      "category": "security",
      "severity": "critical",
      "message": "Security vulnerability detected",
      "recovery": "Fix vulnerability or update dependency"
    },
    "E402": {
      "name": "secret_detected",
      "category": "security",
      "severity": "critical",
      "message": "Hardcoded secret detected",
      "recovery": "Remove secret and use environment variable"
    },
    
    "E501": {
      "name": "harness_skipped",
      "category": "protocol",
      "severity": "critical",
      "message": "Harness evaluation was skipped",
      "recovery": "Run harness before commit"
    },
    "E502": {
      "name": "state_desync",
      "category": "protocol",
      "severity": "critical",
      "message": "State and code out of sync",
      "recovery": "Ensure atomic commit includes state.json"
    },
    "E503": {
      "name": "unregistered_skill",
      "category": "protocol",
      "severity": "high",
      "message": "Used skill not in registry",
      "recovery": "Register skill in index.json or use registered skill"
    },
    
    "E601": {
      "name": "dependency_missing",
      "category": "environment",
      "severity": "critical",
      "message": "Required dependency not installed",
      "recovery": "Install missing dependency"
    },
    "E602": {
      "name": "network_timeout",
      "category": "environment",
      "severity": "high",
      "message": "Network operation timed out",
      "recovery": "Check network connectivity and retry"
    },
    "E603": {
      "name": "disk_full",
      "category": "environment",
      "severity": "critical",
      "message": "Insufficient disk space",
      "recovery": "Free disk space and retry"
    },
    "E604": {
      "name": "permission_denied",
      "category": "environment",
      "severity": "critical",
      "message": "Permission denied for file or resource",
      "recovery": "Check file permissions or run with appropriate privileges"
    },
    "E605": {
      "name": "tool_not_found",
      "category": "environment",
      "severity": "high",
      "message": "Required tool not found in PATH",
      "recovery": "Install tool or update PATH"
    }
  },
  
  "warnings": {
    "W101": {
      "name": "complexity_warning",
      "message": "Function complexity approaching threshold"
    },
    "W201": {
      "name": "coverage_warning",
      "message": "Test coverage below target but above minimum"
    },
    "W301": {
      "name": "risk_analysis_medium",
      "message": "Medium-risk failure mode detected (50 <= RPN < 100)"
    }
  }
}
